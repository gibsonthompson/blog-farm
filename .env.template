# ============================================
# BLOG AUTOMATION — ENVIRONMENT VARIABLES
# Copy to .env.local and fill in values
# ============================================

# Supabase (existing VoiceAI Connect project)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Anthropic (Claude API for content generation + QC)
ANTHROPIC_API_KEY=sk-ant-...

# GitHub (Personal Access Token with "Contents" write permission)
# Create at: https://github.com/settings/tokens
# Scopes needed: repo (classic) OR Contents:write (fine-grained)
GITHUB_TOKEN=ghp_...

# Google Service Account (base64-encoded JSON key)
# Setup:
#   1. Google Cloud Console → Create project or use existing
#   2. Enable "Google Search Console API"
#   3. IAM & Admin → Service Accounts → Create → Download JSON key
#   4. Google Search Console → Settings → Users → Add service account email as Owner
#   5. Encode: cat service-account.json | base64 | tr -d '\n'
GOOGLE_SERVICE_ACCOUNT_KEY=eyJ...base64...

# IndexNow (for Bing/Yandex/DuckDuckGo instant indexing)
# Generate: openssl rand -hex 16
# Then create a file named {key}.txt containing the key
# and commit it to the root of callbird-site repo
INDEXNOW_API_KEY=

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3100
